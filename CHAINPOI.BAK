/* WAP TO SHOW DEMO OF CHAIN OF POINTERS */
#include <stdio.h>
int main()
{
    int a = 10;
    int *p1 = &a;
    int **p2 = &p1;
    int ***p3 = &p2;
    clrscr();

    printf("Value of a: %d\n", a);
    printf("Value of a using p1: %d\n", *p1);
    printf("Value of a using p2: %d\n", **p2);
    printf("Value of a using p3: %d\n", ***p3);

    return 0;
}